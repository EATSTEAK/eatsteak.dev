---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { createImageAssetMap, renderMarpSlides } from "@/utils/marp";
import type { ImageMetadata } from "astro";
import "@/styles/show.css";
import { Button, buttonClassName } from "@/components/ui/Button";
import { ReadingMode } from "@/icons/ReadingMode";
import { ArrowPrevious } from "@/icons/ArrowPrevious";
import { ArrowNext } from "@/icons/ArrowNext";
import { FullscreenMaximize } from "@/icons/FullscreenMaximize";
import MermaidRenderer from "@/components/MermaidRenderer.astro";

// Import all images from src/assets using Vite's glob import
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,webp}",
  { eager: true },
);

export async function getStaticPaths() {
  const slides = await getCollection("slide");
  return slides.map((slide) => ({
    params: { slug: slide.id },
    props: { slide },
  }));
}

type Props = {
  slide: CollectionEntry<"slide">;
};

const { slide } = Astro.props;

const imageMap = createImageAssetMap(images);

const marpResult = renderMarpSlides(slide.body!, { imageMap });
---

<Layout title={slide.data.title} description={slide.data.description}>
  <style set:html={marpResult.css}></style>

  <!-- Slideshow Presentation View -->
  <div class="slideshow-container">
    <div
      class="slideshow-controls fixed bottom-5 right-5 z-30 flex gap-3 items-center backdrop-blur-sm transition-all spring-bounce-10 spring-duration-200 pointer-events-auto p-3 rounded-md overflow-hidden bg-primary-bg/50"
    >
      <button
        id="prev-slide"
        type="button"
        class={buttonClassName("cursor-pointer")}
        aria-label="이전 슬라이드"
      >
        <ArrowPrevious class="size-4" />
      </button>
      <span id="slide-counter">1 / {marpResult.slides.length}</span>
      <button
        id="next-slide"
        type="button"
        class={buttonClassName("cursor-pointer")}
        aria-label="다음 슬라이드"
      >
        <ArrowNext class="size-4" />
      </button>
      <Button href={`/slide/${slide.id}`} aria-label="읽기 모드로 보기">
        <ReadingMode class="size-4" />
      </Button>
      <button
        id="fullscreen"
        type="button"
        class={buttonClassName("cursor-pointer")}
        aria-label="전체 화면 전환"
      >
        <FullscreenMaximize class="size-4" />
      </button>
    </div>

    <div class="slide-viewport marpit" set:html={marpResult.presentationHtml} />
  </div>

  <MermaidRenderer />

  <script>
    type SlideshowState = {
      bound?: boolean;
      cleanup?: () => void;
    };

    const globalWindow = window as typeof window & {
      __eatsteakSlideshow?: SlideshowState;
    };

    const slideshowState = (globalWindow.__eatsteakSlideshow ??= {});

    function setupSlideshow(): (() => void) | undefined {
      let currentSlide = 0;
      const slides = Array.from(
        document.querySelectorAll<HTMLElement>(".slide"),
      );
      if (!slides.length) return undefined;

      const totalSlides = slides.length;
      const counter = document.getElementById("slide-counter");
      const prevBtn = document.getElementById("prev-slide");
      const nextBtn = document.getElementById("next-slide");
      const fullscreenBtn = document.getElementById("fullscreen");
      const controls = document.querySelector<HTMLElement>(
        ".slideshow-controls",
      );
      const abortController = new AbortController();
      const { signal } = abortController;
      const timeouts = new Set<number>();
      let controlsTimeout: number | undefined;

      function scheduleTimeout(callback: () => void, delay: number): number {
        const timeout = window.setTimeout(() => {
          timeouts.delete(timeout);
          callback();
        }, delay);
        timeouts.add(timeout);
        return timeout;
      }

      function clearScheduledTimeout(timeout: number | undefined) {
        if (timeout === undefined) return;

        window.clearTimeout(timeout);
        timeouts.delete(timeout);
      }

      function showSlide(index: number) {
        const currentActiveSlide =
          document.querySelector<HTMLElement>(".slide.active");
        const targetSlide = slides[index];
        if (!targetSlide) return;

        if (currentActiveSlide && currentActiveSlide !== targetSlide) {
          currentActiveSlide.classList.add("slide-exiting");

          scheduleTimeout(() => {
            currentActiveSlide.classList.remove("active", "slide-exiting");
            targetSlide.classList.add("active", "slide-entering");

            scheduleTimeout(() => {
              targetSlide.classList.remove("slide-entering");
            }, 300);
          }, 150);
        } else {
          slides.forEach((slide, i) => {
            slide.classList.toggle("active", i === index);
          });
        }

        if (counter) {
          counter.textContent = `${index + 1} / ${totalSlides}`;
        }
      }

      function nextSlide() {
        currentSlide = (currentSlide + 1) % totalSlides;
        showSlide(currentSlide);
      }

      function prevSlide() {
        currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
        showSlide(currentSlide);
      }

      function showControls() {
        if (controls) {
          controls.style.transform = "translateY(0)";
          controls.style.opacity = "1";
          controls.style.pointerEvents = "auto";
        }
      }

      function hideControls() {
        if (controls) {
          controls.style.transform = "translateY(50%)";
          controls.style.opacity = "0";
          controls.style.pointerEvents = "none";
        }
      }

      function resetControlsTimer() {
        clearScheduledTimeout(controlsTimeout);

        showControls();

        controlsTimeout = scheduleTimeout(() => {
          hideControls();
        }, 3000);
      }

      function fullscreenHandler() {
        const slideshowContainer = document.querySelector(
          ".slideshow-container",
        );
        if (!slideshowContainer) return;

        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else {
          slideshowContainer.requestFullscreen();
        }
      }

      function keydownHandler(e: KeyboardEvent) {
        const target = e.target as HTMLElement | null;
        const isInteractiveTarget = Boolean(
          target?.closest("a, button, input, select, textarea"),
        );

        if (isInteractiveTarget && (e.key === " " || e.key === "Enter")) {
          return;
        }

        switch (e.key) {
          case "ArrowRight":
          case "ArrowDown":
          case " ":
            e.preventDefault();
            nextSlide();
            resetControlsTimer();
            break;
          case "ArrowLeft":
          case "ArrowUp":
            e.preventDefault();
            prevSlide();
            resetControlsTimer();
            break;
          case "Home":
            e.preventDefault();
            currentSlide = 0;
            showSlide(currentSlide);
            resetControlsTimer();
            break;
          case "End":
            e.preventDefault();
            currentSlide = totalSlides - 1;
            showSlide(currentSlide);
            resetControlsTimer();
            break;
          case "Escape":
            window.location.href = `/slide/${window.location.pathname.split("/")[2]}`;
            break;
        }
      }

      showControls();
      resetControlsTimer();

      fullscreenBtn?.addEventListener("click", fullscreenHandler, { signal });
      nextBtn?.addEventListener("click", nextSlide, { signal });
      prevBtn?.addEventListener("click", prevSlide, { signal });
      document.addEventListener("mousemove", resetControlsTimer, { signal });
      document.addEventListener("click", resetControlsTimer, { signal });
      document.addEventListener("keydown", keydownHandler, { signal });

      return () => {
        abortController.abort();
        for (const timeout of timeouts) {
          window.clearTimeout(timeout);
        }
        timeouts.clear();
      };
    }

    function cleanupCurrentSlideshow() {
      slideshowState.cleanup?.();
      slideshowState.cleanup = undefined;
    }

    function initializeCurrentPage() {
      cleanupCurrentSlideshow();
      slideshowState.cleanup = setupSlideshow();
    }

    if (!slideshowState.bound) {
      slideshowState.bound = true;
      document.addEventListener("astro:page-load", initializeCurrentPage);
      document.addEventListener("astro:before-swap", cleanupCurrentSlideshow);
    }

    initializeCurrentPage();
  </script>
</Layout>
