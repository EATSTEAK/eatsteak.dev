---
import { getCollection, type CollectionEntry } from "astro:content";
import { createImageAssetMap, renderMarpSlides } from "@/utils/marp";
import type { MarkdownHeading } from "astro";
import type { ImageMetadata } from "astro";
import "@/styles/slide.css";
import BlogSlide from "@/layouts/BlogSlide.astro";
import MermaidRenderer from "@/components/MermaidRenderer.astro";
import { getReadingTime } from "@/utils/reading-time";

// Import all images from src/assets using Vite's glob import
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,webp}",
  { eager: true },
);

export async function getStaticPaths() {
  const slides = await getCollection("slide");
  return slides.map((slide) => ({
    params: { slug: slide.id },
    props: { slide },
  }));
}

type Props = {
  slide: CollectionEntry<"slide">;
};

const { slide } = Astro.props;

const imageMap = createImageAssetMap(images);

const minutesRead = getReadingTime(slide.body!);

const marpResult = renderMarpSlides(slide.body!, { imageMap });

// Build ToC from the first heading in each Marp slide.
const headings: MarkdownHeading[] = marpResult.slides.flatMap((slideItem) => {
  if (!slideItem.firstHeadingText) return [];

  return [
    {
      depth: 2,
      slug: slideItem.id,
      text: slideItem.firstHeadingText,
    },
  ];
});
---

<BlogSlide slug={slide.id} {...slide.data} {minutesRead} {headings}>
  <style set:html={marpResult.css}></style>
  <section class="slide-document prose" set:html={marpResult.html} />
  <MermaidRenderer />
</BlogSlide>
